# Create new .gitignore file with proper content
@"
# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Environment variables
.env
.env.local
.env.production
.env.development
backend/.env
frontend/.env

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov/

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# Build outputs
dist/
build/
out/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Backend specific
backend/node_modules/
backend/package-lock.json
backend/dist/
backend/build/

# Frontend specific
frontend/node_modules/
frontend/package-lock.json
frontend/dist/
frontend/build/
frontend/.next/

# Testing
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
*.tmp
*.temp
"@ | Out-File -FilePath .gitignore -Encoding UTF8
